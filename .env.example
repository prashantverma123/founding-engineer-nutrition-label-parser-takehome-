# Option 1: Google Gemini
GOOGLE_API_KEY=your-gemini-api-key-here

# Option 2: OpenAI GPT-4V/4o
# OPENAI_API_KEY=your-openai-api-key-here

# Option 3: Anthropic Claude
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Processing Configuration
DEFAULT_PROVIDER=gemini  # auto, gemini, openai, or claude
DEFAULT_MODEL=           # Leave empty for provider default, or specify: gpt-4o, claude-3-5-sonnet-20241022, gemini-2.0-flash-exp
MAX_WORKERS=5            # Number of parallel workers for batch processing
SKIP_DETECTION=false     # Set to true to skip nutrition data detection (process all images)

# Logging
DEBUG=false              # Set to true for detailed logging
